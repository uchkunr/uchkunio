---
export const prerender = true;
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

type Book = {
  title: string;
  author: string;
  note?: string;
};

const currently: Book[] = [
  {
    title: "Designing Data-Intensive Applications",
    author: "Martin Kleppmann",
    note: "Re-reading. Different chapters hit differently once you've shipped the systems they describe.",
  },
];

const recent: Book[] = [
  {
    title: "Database Internals",
    author: "Alex Petrov",
    note: "B-trees, LSM trees, and why your database does what it does on disk.",
  },
  {
    title: "The Pragmatic Programmer",
    author: "David Thomas, Andrew Hunt",
    note: "Holds up surprisingly well twenty years later.",
  },
  {
    title: "A Philosophy of Software Design",
    author: "John Ousterhout",
    note: "Short, opinionated, worth the few hours it takes to read.",
  },
];

const queue: Book[] = [
  { title: "Understanding Distributed Systems", author: "Roberto Vitillo" },
  { title: "Systems Performance", author: "Brendan Gregg" },
  { title: "The Mythical Man-Month", author: "Fred Brooks" },
];
---

<BaseLayout
  title="Reading"
  description="Books I'm reading, recently finished, and planning to read next."
>
  <Breadcrumbs items={[{ name: "Reading", href: "/reading" }]} />
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 sm:py-16">
    <a
      href="/"
      class="inline-flex items-center gap-1.5 text-xs sm:text-sm text-muted-foreground hover:text-foreground transition-colors mb-6 sm:mb-8"
    >
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6l6 6" /></svg>
      Back to home
    </a>

    <header class="mb-8 sm:mb-12 animate-fade-in">
      <p class="text-sm font-medium text-muted-foreground mb-2">reading</p>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight">
        Bookshelf
      </h1>
      <p class="mt-3 text-sm sm:text-base text-muted-foreground leading-relaxed max-w-2xl">
        Mostly engineering books, with the occasional escape into something else.
        I trust books that earned a re-read more than ones I finished once.
      </p>
    </header>

    <div class="space-y-10 animate-fade-in-delay-1">
      <section>
        <h2 class="text-xs uppercase tracking-wider text-muted-foreground font-medium mb-4">Currently reading</h2>
        <ul class="space-y-4">
          {currently.map((b) => (
            <li class="rounded-xl ring-1 ring-foreground/10 bg-card p-4 sm:p-5">
              <p class="text-sm sm:text-base font-semibold">{b.title}</p>
              <p class="text-xs sm:text-sm text-muted-foreground mt-0.5">{b.author}</p>
              {b.note && <p class="text-xs sm:text-sm text-muted-foreground mt-2 leading-relaxed">{b.note}</p>}
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-xs uppercase tracking-wider text-muted-foreground font-medium mb-4">Recently finished</h2>
        <ul class="divide-y divide-border/40 border-y border-border/40">
          {recent.map((b) => (
            <li class="py-4">
              <p class="text-sm sm:text-base font-medium">{b.title}</p>
              <p class="text-xs sm:text-sm text-muted-foreground mt-0.5">{b.author}</p>
              {b.note && <p class="text-xs sm:text-sm text-muted-foreground mt-1.5 leading-relaxed">{b.note}</p>}
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-xs uppercase tracking-wider text-muted-foreground font-medium mb-4">In the queue</h2>
        <ul class="space-y-2">
          {queue.map((b) => (
            <li class="flex flex-wrap items-baseline gap-x-2 text-sm sm:text-base">
              <span class="font-medium">{b.title}</span>
              <span class="text-muted-foreground text-xs sm:text-sm">— {b.author}</span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>
