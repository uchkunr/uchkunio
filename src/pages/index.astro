---
export const prerender = true;
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BIO, SOCIAL_LINKS, SITE } from "@/config/site";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Uchkun Rakhimov",
  alternateName: ["uchkunio", "uchkunr", "Uchkun I/O"],
  url: SITE.url,
  jobTitle: "Backend Engineer",
  description: SITE.description,
  email: "uchkunrakhimov@gmail.com",
  knowsAbout: [
    "Node.js", "TypeScript", "NestJS", "Express.js", "Fastify",
    "PostgreSQL", "MongoDB", "Redis", "GraphQL",
    "Google Cloud Platform", "AWS", "Docker", "CI/CD",
    "Distributed Systems", "API Design", "Backend Engineering",
  ],
  sameAs: SOCIAL_LINKS.map((l) => l.href).filter((h) => !h.startsWith("mailto:")),
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Uchkun I/O",
  alternateName: "uchkun.io",
  url: SITE.url,
  description: SITE.description,
  author: { "@type": "Person", name: "Uchkun Rakhimov" },
};
---

<BaseLayout>
  <Fragment slot="default">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <section class="pt-6 pb-10 sm:pt-10 sm:pb-16 animate-fade-in">
        <div class="relative h-16 w-16 sm:h-20 sm:w-20 mb-4 sm:mb-5 rounded-full overflow-hidden ring-1 ring-foreground/10 bg-gradient-to-br from-primary/30 via-primary/10 to-muted">
          <span
            class="absolute inset-0 flex items-center justify-center text-lg sm:text-xl font-semibold text-foreground/70 select-none"
            aria-hidden="true"
          >
            UR
          </span>
          <img
            src="https://avatars.githubusercontent.com/u/105480357?v=4"
            alt={BIO.name}
            class="absolute inset-0 h-full w-full object-cover"
            onerror="this.style.display='none'"
            loading="eager"
            decoding="async"
          />
        </div>

        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-3 sm:mb-4">
          {BIO.name}
        </h1>

        <div class="prose prose-neutral dark:prose-invert max-w-2xl text-sm sm:text-base text-muted-foreground leading-relaxed sm:leading-7 space-y-4 sm:space-y-5">
          <p>
            I'm a backend engineer and CTO at <a href="https://carlink.pro" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">Carlink</a>.
            I'm from Tashkent, Uzbekistan. I've been building production systems since 2021.
          </p>

          <p>
            I started out at <a href="https://etc.uz" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">East Telecom</a>,
            where I rewrote an old Google Apps Script Telegram bot into a Laravel service.
            It still runs today. After a couple of years there, I went freelance.
          </p>

          <p>
            The freelance period was where I learned the most. I built systems end-to-end for small
            companies: a courier CRM, a WiFi authentication portal across 14 branch offices, a VoIP
            middleware for a call center.
          </p>

          <p>
            More recently I worked remotely for <a href="https://numeo.ai" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">Numeo.ai</a>
            on their Chrome extension backend on GCP, and spent a few months at
            <a href="https://startupsdna.com" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">Startups DNA</a>
            redesigning Fastify APIs and building notification infrastructure on Google Cloud Tasks.
            Since late 2025, I've been CTO at Carlink, an auto transport platform serving the US
            B2B market.
          </p>
        </div>

        <div class="mt-10 sm:mt-14">
          <h2 class="text-sm font-medium text-muted-foreground mb-4 sm:mb-5">technical work</h2>
          <ul class="space-y-3 sm:space-y-3.5 text-sm sm:text-base text-muted-foreground leading-relaxed sm:leading-7 max-w-2xl list-disc pl-5 marker:text-muted-foreground/40">
            <li>
              Architected <a href="https://carlink.pro" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">Carlink</a>,
              a multi-tenant B2B auto transport platform with integrations into Central Dispatch,
              SuperDispatch, and QuickBooks.
            </li>
            <li>
              Built TedbookCRM, a courier CRM with multi-role access, real-time order tracking
              over Socket.IO, and Firebase push notifications to driver mobile apps. Currently
              processes 50+ orders a day.
            </li>
            <li>
              Built a WiFi captive portal handling OTP authentication across 14 branch offices
              through the Ubiquiti UniFi Controller API, serving around a thousand sessions daily.
            </li>
            <li>
              Built a Node.js middleware bridging Asterisk PBX with a live operator dashboard,
              supporting 60+ concurrent agents at sub-second latency.
            </li>
            <li>
              Led the v2 API redesign for Assetsy, a Fastify-based asset management microservice
              at Startups DNA.
            </li>
            <li>
              Built PillPlan's notification engine using GCP Cloud Tasks and APNs, with retry
              logic for failed deliveries.
            </li>
          </ul>
        </div>

        <div class="mt-8 sm:mt-10 text-sm sm:text-base text-muted-foreground leading-relaxed sm:leading-7 max-w-2xl">
          <p>
            I write on <a href="/blog" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">the blog</a>.
            Email is <a href="mailto:uchkunrakhimov@gmail.com" class="font-medium text-foreground underline decoration-foreground/30 underline-offset-4 hover:decoration-foreground transition-colors">uchkunrakhimov@gmail.com</a>.
          </p>
        </div>
      </section>
    </div>
  </Fragment>
</BaseLayout>
