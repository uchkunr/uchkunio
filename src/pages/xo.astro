---
export const prerender = true;
import BaseLayout from "@/layouts/BaseLayout.astro";
import XOGame from "@/components/XOGame";
---

<BaseLayout title="X/O" description="Play Tic-Tac-Toe against AI">
  <div class="mx-auto max-w-xs px-4 py-4 sm:py-8">
    <div class="mb-4 space-y-1 text-center">
      <h1 class="text-xl font-semibold tracking-tight">X/O</h1>
      <p class="text-muted-foreground text-sm">Choose your mark and play against AI.</p>
    </div>
    <XOGame client:load />
  </div>
</BaseLayout>
