---
export const prerender = false;
import AdminLayout from "@/components/admin/AdminLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const latest = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);
---

<AdminLayout title="Dashboard">
  <div class="space-y-8">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Dashboard</h1>
      <p class="text-sm text-muted-foreground mt-1">Welcome back.</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <div class="rounded-xl border border-border bg-card p-4 space-y-1">
        <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Total posts</p>
        <p class="text-3xl font-bold tabular-nums">{posts.length}</p>
      </div>
      <a
        href="/admin/blog/new"
        class="rounded-xl border border-dashed border-border bg-card p-4 flex flex-col items-center justify-center gap-1 text-sm text-muted-foreground hover:bg-accent hover:text-foreground transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <span class="text-xs font-medium">New post</span>
      </a>
    </div>

    <!-- Recent posts -->
    {latest.length > 0 && (
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold">Recent posts</h2>
          <a href="/admin/blog" class="text-xs text-muted-foreground hover:text-foreground transition-colors">View all →</a>
        </div>
        <div class="divide-y divide-border rounded-xl border border-border overflow-hidden">
          {latest.map((post) => (
            <div class="flex items-center justify-between gap-3 bg-card px-4 py-3 hover:bg-accent/40 transition-colors">
              <div class="min-w-0">
                <p class="text-sm font-medium truncate">{post.data.title}</p>
                <p class="text-xs text-muted-foreground mt-0.5">{post.data.date}</p>
              </div>
              <a
                href={`/admin/blog/${post.id}`}
                class="shrink-0 rounded-md border border-border px-2.5 py-1 text-xs font-medium hover:bg-accent transition-colors"
              >
                Edit
              </a>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</AdminLayout>
