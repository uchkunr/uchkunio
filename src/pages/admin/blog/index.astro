---
export const prerender = false;
import AdminLayout from "@/components/admin/AdminLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<AdminLayout title="Blog">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-xl font-semibold tracking-tight">Blog</h1>
      <a
        href="/admin/blog/new"
        class="rounded-lg bg-primary text-primary-foreground px-3 py-1.5 text-sm font-medium hover:opacity-90 transition-opacity"
      >
        New post
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="text-sm text-muted-foreground">No posts yet.</p>
    ) : (
      <div class="divide-y divide-border rounded-xl border border-border overflow-y-auto" style="max-height: calc(10 * 57px)">
        {posts.map((post) => (
          <div class="flex items-center justify-between gap-4 bg-card px-4 py-3 hover:bg-accent/30 transition-colors">
            <div class="min-w-0">
              <p class="text-sm font-medium truncate">{post.data.title}</p>
              <p class="text-xs text-muted-foreground">{post.data.date}</p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a
                href={`/blog/${post.id}`}
                target="_blank"
                class="text-xs text-muted-foreground hover:text-foreground transition-colors"
              >
                View ↗
              </a>
              <a
                href={`/admin/blog/${post.id}`}
                class="rounded-md border border-border px-2.5 py-1 text-xs font-medium hover:bg-accent transition-colors"
              >
                Edit
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
