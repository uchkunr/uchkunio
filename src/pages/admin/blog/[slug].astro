---
export const prerender = false;
import AdminLayout from "@/components/admin/AdminLayout.astro";
import BlogEditor from "@/components/admin/BlogEditor";
import { getFile } from "@/lib/github";
import { parseBlogFile } from "@/lib/frontmatter";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/admin/blog");

let initial;
try {
  const file = await getFile(`src/content/blog/${slug}.md`);
  const { frontmatter, body } = parseBlogFile(file.content);
  initial = { ...frontmatter, body };
} catch {
  return Astro.redirect("/admin/blog");
}
---

<AdminLayout title={initial.title}>
  <div class="space-y-6">
    <div class="flex items-center gap-3">
      <a href="/admin/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Blog</a>
      <span class="text-muted-foreground">/</span>
      <h1 class="text-xl font-semibold tracking-tight truncate">{initial.title}</h1>
    </div>
    <BlogEditor client:load slug={slug} initial={initial} />
  </div>
</AdminLayout>
