---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-16 sm:py-24 text-center">
    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight">404</h1>
    <p class="mt-3 sm:mt-4 text-base sm:text-lg text-muted-foreground">Page not found.</p>
    <a
      href="/"
      class="mt-6 sm:mt-8 inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
    >
      &larr; Go home
    </a>
  </div>
</BaseLayout>
