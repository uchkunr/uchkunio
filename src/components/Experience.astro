---
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { EXPERIENCE } from "@/config/site";
---

<section class="pb-12 sm:pb-16 animate-fade-in-delay-2">
  <h2 class="text-sm font-medium text-muted-foreground mb-4 sm:mb-6">experience</h2>

  <div class="space-y-3 sm:space-y-4">
    {
      EXPERIENCE.map((job, jobIdx) => (
        <Card className={`overflow-hidden transition-colors ${jobIdx === 0 ? "border-primary/20" : ""}`}>
          <CardContent className="p-0">
            {/* Company header */}
            <div class="flex items-center justify-between gap-3 px-4 sm:px-5 pt-4 sm:pt-5 pb-3">
              <div class="flex items-center gap-2.5 min-w-0">
                <div class={`h-9 w-9 sm:h-10 sm:w-10 shrink-0 rounded-lg flex items-center justify-center text-sm sm:text-base font-bold ${jobIdx === 0 ? "bg-primary text-primary-foreground" : "bg-muted text-muted-foreground"}`}>
                  {job.company.charAt(0)}
                </div>
                <div class="min-w-0">
                  <h3 class="text-base sm:text-lg font-semibold truncate">{job.company}</h3>
                  <p class="text-xs sm:text-sm text-muted-foreground">{job.location}</p>
                </div>
              </div>
              {jobIdx === 0 && (
                <Badge variant="secondary" className="shrink-0 text-xs bg-primary/10 text-primary border-0">
                  Current
                </Badge>
              )}
            </div>

            {/* Roles */}
            <div class="px-4 sm:px-5 pb-4 sm:pb-5 space-y-3 sm:space-y-4">
              {job.roles.map((role, roleIdx) => (
                <div class={`${roleIdx > 0 ? "pt-3 sm:pt-4 border-t border-border/50" : ""}`}>
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-0.5 sm:gap-2 mb-2 sm:mb-2.5">
                    <div class="flex items-center gap-1.5 flex-wrap">
                      <span class="text-sm sm:text-base font-medium">{role.title}</span>
                      {("project" in role && role.project) && (
                        <span class="text-xs sm:text-sm text-muted-foreground">· {role.project}</span>
                      )}
                    </div>
                    <span class="text-xs sm:text-sm text-muted-foreground tabular-nums whitespace-nowrap">
                      {role.period}
                    </span>
                  </div>

                  <ul class="space-y-1.5 sm:space-y-2">
                    {role.highlights.map((h) => (
                      <li class="flex gap-2 text-sm sm:text-base text-muted-foreground leading-relaxed">
                        <span class="shrink-0 mt-[8px] sm:mt-[9px] h-1 w-1 rounded-full bg-muted-foreground/30" />
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      ))
    }
  </div>
</section>
