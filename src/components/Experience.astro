---
import { EXPERIENCE } from "@/config/site";

const current = EXPERIENCE[0];
const past = EXPERIENCE.slice(1);
---

<section class="pb-12 sm:pb-16 animate-fade-in-delay-2">
  <h2 class="text-sm font-medium text-muted-foreground mb-4 sm:mb-6">experience</h2>

  <div class="space-y-3">

    <!-- ── Current job ─────────────────────────────── -->
    <div class="relative rounded-xl ring-1 ring-foreground/10 bg-card overflow-hidden">
      <!-- Top accent line -->
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/50 to-transparent" />

      <div class="px-5 pt-5 pb-5">
        <!-- Header -->
        <div class="flex items-start justify-between gap-3 mb-4">
          <div class="flex items-center gap-3 min-w-0">
            <div class="h-10 w-10 shrink-0 rounded-lg overflow-hidden ring-1 ring-foreground/10 flex items-center justify-center bg-muted text-muted-foreground font-bold text-sm">
              {current.website ? (
                <img
                  src={`https://www.google.com/s2/favicons?domain=${current.website}&sz=64`}
                  alt={current.company}
                  class="h-6 w-6 object-contain"
                />
              ) : current.company.charAt(0)}
            </div>
            <div class="min-w-0">
              {current.website ? (
                <a
                  href={`https://${current.website}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold text-base leading-tight hover:underline underline-offset-2 block"
                >
                  {current.company}
                </a>
              ) : (
                <p class="font-semibold text-base leading-tight">{current.company}</p>
              )}
              <p class="text-xs text-muted-foreground mt-0.5">{current.location}</p>
            </div>
          </div>

        </div>

        <!-- Roles -->
        <div class="space-y-4">
          {current.roles.map((role, i) => (
            <div class={i > 0 ? "pt-4 border-t border-border/50" : ""}>
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-0.5 sm:gap-2 mb-2.5">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-semibold">{role.title}</span>
                  {("project" in role && role.project) && (
                    <span class="text-xs text-muted-foreground bg-accent px-2 py-0.5 rounded-md">{role.project}</span>
                  )}
                </div>
                <span class="text-xs text-muted-foreground tabular-nums whitespace-nowrap">{role.period}</span>
              </div>
              <ul class="space-y-2">
                {role.highlights.map((h) => (
                  <li class="flex gap-2.5 text-sm text-muted-foreground leading-relaxed">
                    <span class="shrink-0 mt-[9px] h-1 w-1 rounded-full bg-muted-foreground/40" />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── Past jobs — accordion ────────────────────── -->
    {past.map((job, idx) => (
      <div
        class="exp-item rounded-xl ring-1 ring-foreground/10 bg-card overflow-hidden"
        data-idx={idx}
      >
        <button
          type="button"
          class="exp-trigger w-full flex items-center gap-3 px-5 py-4 text-left hover:bg-accent/40 transition-colors"
          aria-expanded="false"
        >
          <!-- Favicon -->
          <div class="h-8 w-8 shrink-0 rounded-md overflow-hidden ring-1 ring-foreground/10 flex items-center justify-center bg-muted text-muted-foreground font-bold text-xs">
            {job.website ? (
              <img
                src={`https://www.google.com/s2/favicons?domain=${job.website}&sz=32`}
                alt={job.company}
                class="h-5 w-5 object-contain"
              />
            ) : job.company.charAt(0)}
          </div>

          <!-- Info -->
          {(() => {
            const uniqueTitles = [...new Set(job.roles.map(r => r.title))];
            const sameTitle = uniqueTitles.length === 1;
            const projects = job.roles.map(r => r.project).filter(Boolean) as string[];
            const summary = sameTitle
              ? (projects.length > 0 ? `${uniqueTitles[0]} · ${projects.join(" · ")}` : uniqueTitles[0])
              : job.roles.map(r => `${r.title}${r.project ? ` — ${r.project}` : ""}`).join(", ");
            return (
              <div class="flex-1 min-w-0">
                <div class="flex flex-col sm:flex-row sm:items-center sm:gap-2">
                  <span class="text-sm font-semibold truncate">{job.company}</span>
                  <span class="hidden sm:inline text-muted-foreground/40 text-xs">·</span>
                  <span class="text-xs text-muted-foreground truncate">{summary}</span>
                </div>
                <p class="text-xs text-muted-foreground mt-0.5 tabular-nums">
                  {job.roles[0].period}
                  {job.roles.length > 1 && ` · ${job.roles.length} roles`}
                </p>
              </div>
            );
          })()}

          <!-- Chevron -->
          <svg
            class="exp-chevron shrink-0 h-4 w-4 text-muted-foreground transition-transform duration-200"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>

        <!-- Expandable content -->
        <div class="exp-body overflow-hidden" style="max-height: 0; transition: max-height 0.28s ease">
          <div class="exp-inner px-5 pb-5 pt-1 space-y-4 border-t border-border/50">
            {job.roles.map((role, i) => (
              <div class={i > 0 ? "pt-4 border-t border-border/40" : "pt-3"}>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-0.5 sm:gap-2 mb-2.5">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-sm font-semibold">{role.title}</span>
                    {("project" in role && role.project) && (
                      <span class="text-xs text-muted-foreground bg-accent px-2 py-0.5 rounded-md">{role.project}</span>
                    )}
                  </div>
                  <span class="text-xs text-muted-foreground tabular-nums whitespace-nowrap">{role.period}</span>
                </div>
                <ul class="space-y-2">
                  {role.highlights.map((h) => (
                    <li class="flex gap-2.5 text-sm text-muted-foreground leading-relaxed">
                      <span class="shrink-0 mt-[9px] h-1 w-1 rounded-full bg-muted-foreground/40" />
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  function initExperience() {
    document.querySelectorAll<HTMLElement>(".exp-item").forEach((item) => {
      const trigger = item.querySelector<HTMLButtonElement>(".exp-trigger")!;
      const body = item.querySelector<HTMLElement>(".exp-body")!;
      const inner = item.querySelector<HTMLElement>(".exp-inner")!;
      const chevron = item.querySelector<SVGElement>(".exp-chevron")!;

      trigger.addEventListener("click", () => {
        const open = trigger.getAttribute("aria-expanded") === "true";

        if (open) {
          body.style.maxHeight = "0";
          trigger.setAttribute("aria-expanded", "false");
          chevron.style.transform = "";
        } else {
          body.style.maxHeight = inner.scrollHeight + "px";
          trigger.setAttribute("aria-expanded", "true");
          chevron.style.transform = "rotate(180deg)";
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initExperience);
</script>
