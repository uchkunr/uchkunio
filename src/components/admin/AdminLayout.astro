---
import "@/styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
const pathname = Astro.url.pathname;

const nav = [
  {
    href: "/admin",
    label: "Dashboard",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  },
  {
    href: "/admin/blog",
    label: "Blog",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Admin</title>
    <script is:inline>
      const t = localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.classList.toggle("dark", t === "dark");
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <div class="flex min-h-screen">

      <!-- Sidebar (desktop) -->
      <aside class="hidden md:flex w-60 flex-col border-r border-border bg-card px-3 py-6 shrink-0 fixed inset-y-0 left-0">
        <a href="/admin" class="px-3 mb-8 flex items-center gap-2">
          <span class="text-sm font-bold tracking-tight">uchkun.io</span>
          <span class="text-xs text-muted-foreground bg-accent px-1.5 py-0.5 rounded font-medium">admin</span>
        </a>
        <nav class="flex flex-col gap-0.5 flex-1 min-h-0">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors",
                pathname === item.href
                  ? "bg-primary text-primary-foreground"
                  : "text-muted-foreground hover:bg-accent hover:text-foreground",
              ]}
            >
              <Fragment set:html={item.icon} />
              {item.label}
            </a>
          ))}
        </nav>
        <div class="border-t border-border pt-3 mt-auto">
          <form action="/api/admin/logout" method="POST">
            <button
              type="submit"
              class="w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Sign out
            </button>
          </form>
        </div>
      </aside>

      <!-- Mobile drawer backdrop -->
      <div
        id="drawer-backdrop"
        class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
        aria-hidden="true"
      ></div>

      <!-- Mobile drawer -->
      <aside
        id="mobile-drawer"
        class="fixed inset-y-0 left-0 w-72 bg-card border-r border-border z-40 flex flex-col px-3 py-6 transform -translate-x-full transition-transform duration-200 ease-in-out md:hidden"
      >
        <div class="flex items-center justify-between px-3 mb-8">
          <a href="/admin" class="flex items-center gap-2">
            <span class="text-sm font-bold tracking-tight">uchkun.io</span>
            <span class="text-xs text-muted-foreground bg-accent px-1.5 py-0.5 rounded font-medium">admin</span>
          </a>
          <button id="close-drawer" class="p-1 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent transition-colors" aria-label="Close menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <nav class="flex flex-col gap-1 flex-1">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 rounded-lg px-3 py-3 text-sm font-medium transition-colors",
                pathname === item.href
                  ? "bg-primary text-primary-foreground"
                  : "text-muted-foreground hover:bg-accent hover:text-foreground",
              ]}
            >
              <Fragment set:html={item.icon} />
              {item.label}
            </a>
          ))}
        </nav>
        <div class="border-t border-border pt-4 mt-4">
          <form action="/api/admin/logout" method="POST">
            <button
              type="submit"
              class="w-full flex items-center gap-3 rounded-lg px-3 py-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Sign out
            </button>
          </form>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col min-w-0 md:ml-60">
        <!-- Mobile top bar -->
        <header class="md:hidden sticky top-0 z-20 flex items-center justify-between border-b border-border bg-card px-4 h-14">
          <button
            id="open-drawer"
            class="p-2 -ml-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
            aria-label="Open menu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <span class="text-sm font-semibold absolute left-1/2 -translate-x-1/2">{title}</span>
          <a href="/" target="_blank" class="p-2 -mr-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-colors" aria-label="View site">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </header>

        <main class="flex-1 px-4 py-6 sm:px-6 sm:py-8 max-w-5xl w-full mx-auto">
          <slot />
        </main>
      </div>
    </div>

    <script>
      const openBtn = document.getElementById("open-drawer");
      const closeBtn = document.getElementById("close-drawer");
      const drawer = document.getElementById("mobile-drawer");
      const backdrop = document.getElementById("drawer-backdrop");

      function openDrawer() {
        drawer?.classList.remove("-translate-x-full");
        backdrop?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }

      function closeDrawer() {
        drawer?.classList.add("-translate-x-full");
        backdrop?.classList.add("hidden");
        document.body.style.overflow = "";
      }

      openBtn?.addEventListener("click", openDrawer);
      closeBtn?.addEventListener("click", closeDrawer);
      backdrop?.addEventListener("click", closeDrawer);
    </script>
  </body>
</html>
