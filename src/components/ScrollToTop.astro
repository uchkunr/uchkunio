<button
  id="scroll-to-top"
  aria-label="Scroll to top"
  class="fixed bottom-6 right-6 z-50 hidden h-10 w-10 flex items-center justify-center rounded-full border border-input bg-background/80 backdrop-blur-sm shadow-sm transition-all hover:bg-accent hover:text-accent-foreground cursor-pointer"
>
  <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
    <path d="M80,120h96l-48-48Z" opacity="0.2"></path>
    <path d="M213.66,154.34l-80-80a8,8,0,0,0-11.32,0l-80,80a8,8,0,0,0,11.32,11.32L128,91.31l74.34,74.35a8,8,0,0,0,11.32-11.32Z"></path>
  </svg>
</button>

<script is:inline>
  var scrollBtn = document.getElementById("scroll-to-top");

  window.addEventListener("scroll", function () {
    if (!scrollBtn) return;
    scrollBtn.style.display = window.scrollY > 300 ? "inline-flex" : "none";
  }, { passive: true });

  scrollBtn && scrollBtn.addEventListener("click", function () {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
