---

---

<div
  id="floating-controls"
  class="fixed bottom-6 right-6 z-50 flex-col items-center gap-2"
  style="display: none;"
>
  <!-- Theme toggle -->
  <button
    data-theme-toggle
    id="floating-theme-toggle"
    aria-label="Toggle theme"
    class="h-12 w-12 flex items-center justify-center rounded-full border border-input bg-card shadow-sm transition-all hover:bg-accent hover:text-accent-foreground cursor-pointer"
  >
    <svg class="h-[20px] w-[20px] dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
    </svg>
    <svg class="hidden h-[20px] w-[20px] dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4" />
      <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" />
    </svg>
  </button>

  <!-- Scroll to top -->
  <button
    id="scroll-to-top"
    aria-label="Scroll to top"
    class="h-12 w-12 flex items-center justify-center rounded-full border border-input bg-card shadow-sm transition-all hover:bg-accent hover:text-accent-foreground cursor-pointer"
  >
    <svg class="h-[20px] w-[20px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5l0 14" /><path d="M18 11l-6 -6" /><path d="M6 11l6 -6" />
    </svg>
  </button>
</div>
