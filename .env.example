# Admin panel
ADMIN_PASSWORD=         # strong password for /admin login
ADMIN_SECRET=           # random secret for signing session cookies (openssl rand -hex 32)

# GitHub API — used by admin panel to read/write content
# Token needs: repo scope (Contents: read & write)
GITHUB_TOKEN=           # github.com → Settings → Developer settings → Personal access tokens

# Upstash Redis — rate limiting (3 failed logins = 1 week IP block)
# Free tier: upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
